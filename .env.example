APP_NAME=VaultMind
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000

LLM_PROVIDER=groq
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
